"""Write a program to print all numbers from 1 to 100 using a for loop."""
for i in range(1, 101):
    print(i)
    i = i + 1
"""Multiplication Table"""
table = int(input("Enter a table : "))
for i in range(1, 11):
    print(f"{table} X", i,"=", table*i)
"""Count Even and Odd Numbers"""
for i in range(1, 11):
    if i % 2 == 0:
        print(i)
"""Find the largest number"""
largest = 0
for i in range(1, 6):
    num =int(input(f"Enter number {i} : "))
    if i == 1:
        largest = num
    else:
        if num > largest:
            largest = num
print("Largest number of :", largest)
"""Count Positive, Negative, and Zero"""
positive = 0
negative = 0
zero = 0
for i in range(1, 11):
    num =int(input(f"Enter a number{i} : "))
    if num > 0:
        positive +=1
    elif num < 0:
        negative +=1
    else:
        zero +=1
print("Positive number : ", positive)
print("Negative number : ", negative)
print("Zeros :", zero)
