# Create a function to find the smallest of three numbers.
def smallest_number(a, b, c):
    if a <= b and a <= c:
        print("Smallest Number =", a)
    elif b <= a and b <= c:
        print("Smallest Number =", b)
    else:
        print("Smallest Number =", c)
num1 = int(input("Enter First number :"))
num2 = int(input("Enter Second number :"))
num3 = int(input("Enter Third number :"))
smallest_number(num1, num2, num3)

# Create a function to count uppercase letters in a string.
def count_uppercase(str):
    count = 0
    for ch in str:
        if ch.isupper():
            count += 1
    print("Uppercase Letter =", count)
text = input("Enter Teaxt :")
count_uppercase(text)

# Create a function to check whether a year is a leap year.

def leap_year(year):
    if year % 4 == 0 and year % 400 == 0:
        print("This is a leap year")
    else:
        print("This is not a leap year")
years = int(input("Enter years :"))
leap_year(years)

# Create a function to print the multiplication table of a number.

def multiplication_table(num):
    for i in range(1, 11):
        print(num, "x", i, "=", num * i)
number = int(input("Enter number :"))
multiplication_table(number)

# Create a function to count even numbers in a list.
def count_even(num):
    count = 0
    for i in num:
        if i % 2 == 0:
            count += 1
    print("Even number count =", count)

number = [10, 15, 22, 33, 40, 55, 60]

count_even(number)

