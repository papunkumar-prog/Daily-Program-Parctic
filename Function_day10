# Create a function to count the words in a sentence.

def count_word(text):
    count = 1
    for i in text:
        if i == " ":
            count += 1
    print("total word =",count)

str = input("Enter a sentence : ")
count_word(str)

# Create a menu-driven calculator using functions (add, subtract, multiply, divide).

def add(a, b):
    print("Addition=", a + b)

def subtract(a, b):
    print("subtract =", a - b)

def multiply(a, b):
    print("multiply =", a * b)

def divide(a, b):
    if b == 0:
        print("Division by zero is not possible.")
    else:
        print("divide =", a / b)

while True:
    print("\n===== Calculator Menu ======")
    print("1. Addition")
    print("2. Subtract")
    print("3. Multiplication")
    print("4. Division")
    print("5. Exit")
    ch = int(input("Enter your choice :"))
    if ch == 5:
        print("Thank you!")
        break
    if ch >= 1 and ch <=4:
        num1 = int(input("Enter first number :"))
        num2 = int(input("Enter second number :"))
        if ch == 1:
            add(num1, num2)
        elif ch == 2:
            subtract(num1, num2)
        elif ch == 3:
            multiply(num1, num2)
        elif ch == 4:
            divide(num1, num2)
    else:
        print("Invalid Choice! Please try again")
