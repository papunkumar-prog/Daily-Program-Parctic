# Check Even or Odd
def even_odd(num):
    if num % 2 == 0:
        print("Even number")
    else:
        print("Odd number")
number = int(input("Enter a number :"))
even_odd(number)
# Find Square of a Number
def square(num):
    print("Square =", num * num)
number = int(input("Enter a number :"))
square(number)
# Find Factorial
def factorial(num):
    fact = 1
    for i in range(1, num + 1):
        fact = fact * i
    print("Factorial =", fact)
number = int(input("Enter a number :"))
factorial(number)
# Count Vowels in a String
def count_vowels(text):
    count = 0

    for ch in text.lower():
        if ch in 'aeiou':
            count += 1
    print("Total vowel =", count)
sentenc = input("Enter sentenc :")
count_vowels(sentenc)
# Reverse a String

def reverse_string(text):
    print("Reversed =", text[::-1])
word = input("Enter new word :")
reverse_string(word)

# Find the Sum of Numbers from 1 to N

def total(n):
    sum = 0
    for i in range(1, n + 1):
        sum += i
    print("Total =", sum)
number = int(input("Enter a number :"))
total(number)
