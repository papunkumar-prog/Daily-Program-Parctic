import numpy as np


def header(title):
    print("\n" + "-" * 78)
    print(title)
    print("-" * 78)

def f_zeros():
    header("f_zeros() -> np.zeros()")
    resolt = np.zeros((2,3))
    print("np.zeros((2,3)): \n", resolt)
    return resolt
f_zeros()

def f_ones():
    header("f_ones() -> np.ones()")
