def f_ndim():
    arr = np.array([[9,8,7],
                   [6,5,4]])
    print("arr :\n", arr)
    print("arr.ndim:", arr.ndim,"-> 2 axes (rows, columns)")
    return arr.ndim
f_ndim()

def f_shape():
    arr = np.array([[9,8,7],
                    [6,5,4]])
    print("np.array([[9,8,7],[6,5,4]]);\n", arr)
    print("arr.shape:", arr.shape, "-> 2 rows, 3 columns")
    return np.shape
f_shape()


def f_size():
    arr = np.array([[1,2,3],[4,5,6]])
    print(arr)
    print("Total element of array:", arr.size)
    return arr
f_size()

def f_dtype():
    arr = np.array([1,2,3])
    arr_float = np.array([1.2, 3.1, 4.0])
    print("np.array([1,2,3]):", arr.dtype)
    print("np.array([1.2, 3.1, 4.0]):", arr_float.dtype)
    return arr.dtype
f_dtype()

def f_itemsize():
    header("f_itemsize -> arr.itemsize")
    arr_int8 = np.array([1,2,3], dtype = np.int8)
    arr_int64 = np.array([1,2,3], dtype = np.int64)
    print("int8 itemsize", arr_int8.itemsize, "bytes per element")
    print("int64 itemsize", arr_int64.itemsize, "bytes per element")
    return arr_int64.itemsize
f_itemsize()

def f_nbytes():
    header("f_nbytes() -> arr.nbytes()")
    arr = np.zeros((1000, 1000), dtype = np.float64)
    print("Array shape:", arr.shape, "dtype:", arr.dtype)
    print("arr.nbytes:", arr.nbytes, "bytes(~", arr.nbytes / 1e6, "MB)")
    return arr.nbytes
f_nbytes()

def f_T():
