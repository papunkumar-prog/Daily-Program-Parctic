f_base()

def f_reshape():
    header("f_reshape() -> arr.reshape()")
    arr = np.arange(12)
    print("original: ", arr)
    result = arr.reshape(3, 4)
    print("arr.reshape(3, 4) \n", result)
    return result

f_reshape()

def f_flatten():
    header("f_flatten() -> arr.flatten()")
    arr = np.array([[1,2,3],[4,5,6]])
    result = arr.flatten()
    result[0] = 999
    print("original arr:\n", arr)
    print("flatten copy (modified):\n", result)
    return result
f_flatten()

def f_ravel():
    header("f_ravel -> arr.ravel")
    arr = np.array([[1,2,3], [4,5,6]])
    result = arr.ravel()
    print("original arr:\n", arr)
    result[0] = 999
    
    print("arr.ravel:\n", result)
    return result
f_ravel()

def f_transpose():
    header("f_transpose -> arr.transpose")
    arr = np.arange(24).reshape(2, 3, 4)
    print("original shape:", arr.shape)
    result = np.transpose(arr, axes = (1,0,2))
    print("transposed shape (0<->1 axes swap kiye):", result.shape)
    return result
f_transpose()
