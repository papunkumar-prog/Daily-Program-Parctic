"""Project: Student Attendance System (Using Set)"""

attendance = set()
while True:
    print("\n======Students Attendance System======")
    print("1. Add Student")
    print("2. Remove student")
    print("3. View All Student")
    print("4. Search student")
    print("5. Count Student")
    print("6. Clear Student")
    print("7. Exit")

    ch = int(input("Enter your Choice : "))
    #Add Student
    if ch == 1:
        name = input("Enter your name : ")
        if name in attendance:
            print("Student already exists")
        else:
            attendance.add(name)
            print("Attendance add successfully!")
    #Remove Student
    elif ch == 2:
        name = input("Enter name : ")
        if name in attendance:
